# 实验报告助手 环境变量
# 复制此文件为 .env 并填入真实值
# 注意: .env 不应提交到 git

APP_ENV=local
DATABASE_URL=sqlite:///./data/app.db
PROJECT_DATA_ROOT=./data/projects

# 大模型（V1 暂不使用真实 DeepSeek）
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=

# 任务单与证据生成（默认使用本地规则，不依赖外网）
REQUIREMENT_DRAFT_PROVIDER=local_rule
EVIDENCE_DRAFT_PROVIDER=local_rule

# 公开 URL 获取上界
SOURCE_FETCH_TIMEOUT_SECONDS=15
SOURCE_FETCH_MAX_BYTES=20971520
SOURCE_UPLOAD_MAX_BYTES=20971520
