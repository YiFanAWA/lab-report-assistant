# 实验报告助手 Docker 环境变量配置模板
# 使用方法：复制本文件为 .env，根据需要修改后使用 docker compose up
# 注意：.env 文件不提交到 git（已在 .gitignore 排除）

# === 核心配置 ===
APP_ENV=docker
# 数据库路径必须指向 volume 挂载路径，保证持久化
# 注意：SQLite 绝对路径需要 4 个斜杠（sqlite://// + 绝对路径），3 个斜杠会被 SQLAlchemy 解析为相对路径
DATABASE_URL=sqlite:////app/data/db/app.db
# 项目数据根目录必须指向 volume 挂载路径
PROJECT_DATA_ROOT=/app/data/projects

# === LLM 配置（默认 LocalRule，无需 API Key）===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_TEMPERATURE=0.3
# Provider 切换：local_rule（默认）或 deepseek
REQUIREMENT_DRAFT_PROVIDER=local_rule
EVIDENCE_CARD_PROVIDER=local_rule
ANALYSIS_PLAN_PROVIDER=local_rule
CODE_TASK_PROVIDER=local_rule
OUTLINE_PROVIDER=local_rule

# === LLM 调用缓存（SPEC 0014）===
# 是否启用 LLM 调用缓存（默认关闭，启用后相同输入复用 LLM 返回）
# true=启用，false/空/非法值=禁用（默认，行为与 SPEC 0007 一致）
LLM_CACHE_ENABLED=false
# 缓存有效期（秒），默认 86400（1 天）；<=0 视为禁用；非数字降级到 86400
LLM_CACHE_TTL_SECONDS=86400
# 缓存 SQLite 文件路径（留空使用默认 server/data/llm_cache/llm_cache.db）
# Docker 环境建议指向 volume 挂载路径以持久化
LLM_CACHE_DB_PATH=/app/data/llm_cache/llm_cache.db

# === Worker 配置 ===
WORKER_POLL_INTERVAL_SECONDS=1
JOB_MAX_RETRIES=2
JOB_RETRY_BACKOFF_SECONDS=5

# === 公开资料采集 ===
SOURCE_FETCH_TIMEOUT_SECONDS=30
SOURCE_FETCH_MAX_SIZE_BYTES=10485760

# === Python 执行沙箱（容器内）===
EXECUTION_TIMEOUT_SECONDS=30
EXECUTION_MEMORY_LIMIT_MB=1024
EXECUTION_OUTPUT_MAX_BYTES=10485760

# === 数据集与交付物 ===
DATASET_MAX_SIZE_BYTES=52428800
DELIVERABLE_MAX_SIZE_BYTES=52428800
WORD_TEMPLATE_PATH=
PPT_TEMPLATE_PATH=

# === 数据保留 ===
# 0=永久保留（默认），>0=保留 N 天后可清理
DATA_RETENTION_DAYS=0

# === 时区 ===
TZ=Asia/Shanghai
